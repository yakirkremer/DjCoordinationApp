# Dropbox — admin import only (files are copied to server, not streamed)
# Create app at https://www.dropbox.com/developers/apps
# Permissions: files.metadata.read, files.content.read
# Redirect URI: http://localhost:5173/dropbox/callback (and your production URL)
VITE_DROPBOX_APP_KEY=your_app_key_here

# Admin password — required in production (protects writes, Dropbox import, and /music files)
ADMIN_SECRET=change_me_to_a_long_random_password

# Optional separate signing key for session cookies (defaults to ADMIN_SECRET)
SESSION_SECRET=

# Set to 0 only for local debugging without login
# REQUIRE_AUTH=0

# Render persistent disk mount path
STORAGE_ROOT=/var/data

# Local dev uses public/data and public/music — Render uses /var/data disk only.
# Do not commit runtime JSON or MP3s; npm run deploy excludes them automatically.

# Compress MP3 on upload (requires ffmpeg-static). Set to 0 to disable.
AUDIO_TRANSCODE=1
# Lower = smaller files, faster load. 96k is fine for preview listening.
AUDIO_BITRATE=128k

NODE_ENV=production
