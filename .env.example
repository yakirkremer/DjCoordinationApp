# Dropbox — admin import only (files are copied to server, not streamed)
# Create app at https://www.dropbox.com/developers/apps
# Permissions: files.metadata.read, files.content.read
# Redirect URI: http://localhost:5173/dropbox/callback (and your production URL)
VITE_DROPBOX_APP_KEY=your_app_key_here

# Optional: server refresh token so import works without admin OAuth in browser
DROPBOX_REFRESH_TOKEN=

NODE_ENV=production
