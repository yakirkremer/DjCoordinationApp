# Dropbox app key (public) — create an app at https://www.dropbox.com/developers/apps
# App type: Scoped access · Permissions: files.metadata.read, files.content.read
# Redirect URI: http://localhost:5173/dropbox/callback
VITE_DROPBOX_APP_KEY=your_app_key_here

# Optional: server-side refresh token so couples can stream without logging into Dropbox.
# After admin connects Dropbox once, copy the refresh token from browser devtools
# (localStorage key kramer-music-dropbox-v1) or from the OAuth response.
DROPBOX_REFRESH_TOKEN=
